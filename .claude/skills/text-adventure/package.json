{
  "name": "tag-cli",
  "version": "1.4.0",
  "description": "Text Adventure Games — deterministic game engine CLI",
  "type": "module",
  "bin": {
    "tag": "./cli/tag.ts"
  },
  "scripts": {
    "check": "bun run typecheck && bun run lint && bun run format:check && bun run check:generated-assets && bun test",
    "check:generated-assets": "bun ./scripts/check-generated-assets.ts",
    "format": "prettier --write . --ignore-unknown",
    "format:check": "prettier --check . --ignore-unknown",
    "lint": "eslint . --ext .ts",
    "test": "bun test",
    "typecheck": "bun x tsc --noEmit -p ./cli/tsconfig.json"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bun": "^1.3.11",
    "eslint": "^10.2.1",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0"
  },
  "engines": {
    "bun": ">=1.1.0"
  }
}

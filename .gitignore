# Local configuration
*.local.md

# Memory (managed by memory CLI, not shared)
.claude/memory/
.claude/agent-memory/
.claude/accord/

# Node modules (dev-only type definitions — Bun installs via setup.sh)
node_modules/

# Cache and temporary files
*.cache
.cache/
.claude/cache/
tmp/
*.tmp

# Zip archives (except root-level distribution files)
.claude/**/*.zip

# Logs
*.log
logs/

# SDD & TDD ignore
.tddignore
.specify/

# OS files
.DS_Store
Thumbs.db

# PDF source files (too large for git)
star-wars-rpg/*.pdf
